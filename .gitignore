# =============================================================================
# DeepMail Dashboard .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# -----------------------------------------------------------------------------
# Next.js
# -----------------------------------------------------------------------------
.next/
out/
.vercel/
next-env.d.ts

# -----------------------------------------------------------------------------
# Build Artifacts
# -----------------------------------------------------------------------------
**/target/
**/dist/
**/build/
*.tsbuildinfo
graphify-out/
tmp/
.opencode/
docs/
# -----------------------------------------------------------------------------
# Environment and Secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.template
**/.env
**/.env.*
!**/.env.example
!**/.env.template

# -----------------------------------------------------------------------------
# Cryptographic Material
# -----------------------------------------------------------------------------
*.pem
*.key
*.crt
*.p12
*.pfx
*.keystore
*.jks
*.der
*.pkcs8

# -----------------------------------------------------------------------------
# Debug Logs
# -----------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
bun-debug.log*
pnpm-debug.log*
lerna-debug.log*

# -----------------------------------------------------------------------------
# Editor and IDE
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
*.bak
*.cache
*.sublime-*
session-*

# -----------------------------------------------------------------------------
# OS Files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# Version Control Artifacts
# -----------------------------------------------------------------------------
*.orig
*.rej
*.patch

# -----------------------------------------------------------------------------
# Dev Tools and Temp Files
# -----------------------------------------------------------------------------
.tmp/
.temp/
*.tmp
*.temp

# -----------------------------------------------------------------------------
# Test and Coverage
# -----------------------------------------------------------------------------
coverage/
.lcov

# -----------------------------------------------------------------------------
# Database Files
# -----------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3

# -----------------------------------------------------------------------------
# Infrastructure State
# -----------------------------------------------------------------------------
.terraform/
*.tfstate
*.tfstate.*
.vagrant/

# -----------------------------------------------------------------------------
# Turbo
# -----------------------------------------------------------------------------
.turbo/

# -----------------------------------------------------------------------------
# Public assets (default Next SVGs, regenerate if needed)
# -----------------------------------------------------------------------------
public/file.svg
public/globe.svg
public/next.svg
public/vercel.svg
public/window.svg

# -----------------------------------------------------------------------------
# AI/Agent tooling files
# -----------------------------------------------------------------------------
AGENTS.md
CLAUDE.md

# -----------------------------------------------------------------------------
# Sensitive Local Config
# -----------------------------------------------------------------------------
**/*.local
